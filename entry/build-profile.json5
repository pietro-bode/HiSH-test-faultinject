{
  "apiType": "stageMode",
  "buildOption": {
    "externalNativeOptions": {
      "path": "./src/main/cpp/CMakeLists.txt",
      "arguments": "-DCMAKE_BUILD_TYPE=Debug",
      "cppFlags": "-g",
      "abiFilters": [
//        "arm64-v8a",
        "x86_64"
      ]
    }
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": false,
            "files": [
              "./obfuscation-rules.txt"
            ]
          }
        }
      },
      "nativeLib": {
        "debugSymbol": {
          "strip": true,
          "exclude": []
        }
      }
    },
    {
      "name": "debug",
      "nativeLib": {
        "debugSymbol": {
          "strip": false,
          "exclude": []
        }
      }
    }
  ],
  "targets": [
    {
      "name": "entry"
    },
    {
      "name": "ohosTest",
    }
  ]
}